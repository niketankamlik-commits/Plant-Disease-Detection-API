# Plant Disease Detection API Configuration Templates

# Get your FREE API key at https://admin.kindwise.com/
PLANT_ID_API_KEY=your_plant_id_api_key_here
PLANT_ID_API_URL=https://api.plant.id/v3/health_assessment

# Database Configuration
# SQLite: sqlite:///./plantcare.db
# PostgreSQL: postgresql://user:password@localhost/dbname
SQLALCHEMY_DATABASE_URL=sqlite:///./plantcare.db

# TensorFlow Logging (0 = all, 1 = INFO, 2 = WARNING, 3 = ERROR)
TF_ENABLE_ONEDNN_OPTS=0
TF_CPP_MIN_LOG_LEVEL=2

# App Configuration
APP_HOST=127.0.0.1
APP_PORT=8000

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001
